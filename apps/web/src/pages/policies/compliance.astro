---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import CompliancePage from '../../components/automations/CompliancePage';
import Breadcrumbs from '../../components/layout/Breadcrumbs';

const policyId = Astro.url.searchParams.get('policyId') ?? undefined;
---

<DashboardLayout title="Compliance Dashboard">
  <Breadcrumbs client:load items={[
    { label: 'Policies', href: '/policies' },
    { label: 'Compliance' }
  ]} />
  <CompliancePage policyId={policyId} client:load />
</DashboardLayout>
