---
import Layout from '../../../layouts/Layout.astro';
import ProxyTunnelPage from '../../../components/remote/ProxyTunnelPage';

const { tunnelId } = Astro.params;
const target = Astro.url.searchParams.get('target') || '';

if (!tunnelId) {
  return Astro.redirect('/remote');
}
---

<Layout title="Network Proxy">
  <div class="h-[calc(100vh-1rem)]">
    <ProxyTunnelPage
      tunnelId={tunnelId}
      target={target}
      client:only="react"
    />
  </div>
</Layout>
