FROM node:25-alpine@sha256:bdf2cca6fe3dabd014ea60163eca3f0f7015fbd5c7ee1b0e9ccb4ced6eb02ef4 AS base
RUN corepack enable && corepack prepare pnpm@9.15.7 --activate

FROM base AS deps
WORKDIR /app
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml* ./
COPY apps/web/package.json ./apps/web/
COPY packages/shared/package.json ./packages/shared/
RUN pnpm install --frozen-lockfile

FROM base AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/web/node_modules ./apps/web/node_modules
COPY --from=deps /app/packages/shared/node_modules ./packages/shared/node_modules
COPY . .
ARG PUBLIC_API_URL=""
ARG PUBLIC_APP_VERSION="0.1.0"
ARG PUBLIC_ENABLE_REGISTRATION="false"
ENV PUBLIC_API_URL=${PUBLIC_API_URL}
ENV PUBLIC_APP_VERSION=${PUBLIC_APP_VERSION}
ENV PUBLIC_ENABLE_REGISTRATION=${PUBLIC_ENABLE_REGISTRATION}
RUN pnpm --filter @breeze/web build
# Create a self-contained deployment (resolves pnpm symlinks)
RUN pnpm --filter @breeze/web deploy --prod /deployed

FROM base AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV HOST=0.0.0.0

RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 astro

# Copy the self-contained deployment (flat node_modules, no symlinks)
COPY --from=builder --chown=astro:nodejs /deployed/node_modules ./node_modules
COPY --from=builder --chown=astro:nodejs /deployed/dist ./dist
COPY --from=builder --chown=astro:nodejs /deployed/package.json ./

USER astro

EXPOSE 4321
CMD ["node", "./dist/server/entry.mjs"]
