# Development Dockerfile for Web with hot-reloading
FROM node:24-alpine

# Install pnpm (pinned to match prod / packageManager field)
RUN npm install -g pnpm@10.33.4

# Set working directory
WORKDIR /app

# Copy workspace configuration
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml* ./
COPY turbo.json tsconfig.json ./

# Copy package.json files for dependency installation
COPY apps/web/package.json ./apps/web/
COPY packages/shared/package.json ./packages/shared/
# apps/web depends on @breeze/extension-web-sdk — the manifest MUST be present
# or pnpm install fails with ERR_PNPM_WORKSPACE_PKG_NOT_FOUND and the container
# crash-loops. (The production web image got this fix in a5e457211; the dev
# image needs it too.)
COPY packages/extension-web-sdk/package.json ./packages/extension-web-sdk/

# Install all dependencies (including devDependencies for development)
RUN pnpm install

# Copy source code (will be overridden by volume mounts in dev)
COPY apps/web ./apps/web
COPY packages/shared ./packages/shared
COPY packages/extension-web-sdk ./packages/extension-web-sdk

# Set working directory to web
WORKDIR /app/apps/web

# Expose port
EXPOSE 4321

# Sync dependencies on container start so package.json changes don't break hot-reload.
CMD ["sh", "-lc", "pnpm install --prefer-offline --no-frozen-lockfile && pnpm dev --host 0.0.0.0"]
